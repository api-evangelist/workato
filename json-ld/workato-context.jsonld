{
  "@context": {
    "@version": 1.1,
    "workato": "https://www.workato.com/vocab/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Recipe": {
      "@id": "workato:Recipe",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "schema:description"
        },
        "running": {
          "@id": "workato:running",
          "@type": "xsd:boolean"
        },
        "folder_id": {
          "@id": "workato:folderId",
          "@type": "xsd:integer"
        },
        "trigger_application": {
          "@id": "workato:triggerApplication"
        },
        "action_applications": {
          "@id": "workato:actionApplications",
          "@container": "@set"
        },
        "stop_cause": {
          "@id": "workato:stopCause"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "stopped_at": {
          "@id": "workato:stoppedAt",
          "@type": "xsd:dateTime"
        },
        "job_succeeded_count": {
          "@id": "workato:jobSucceededCount",
          "@type": "xsd:integer"
        },
        "job_failed_count": {
          "@id": "workato:jobFailedCount",
          "@type": "xsd:integer"
        },
        "version_no": {
          "@id": "workato:versionNumber",
          "@type": "xsd:integer"
        }
      }
    },

    "Genie": {
      "@id": "workato:Genie",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "schema:description"
        },
        "state": {
          "@id": "workato:state"
        },
        "instructions": {
          "@id": "workato:instructions"
        },
        "ai_provider": {
          "@id": "workato:aiProvider"
        },
        "folder_id": {
          "@id": "workato:folderId",
          "@type": "xsd:integer"
        },
        "skills": {
          "@id": "workato:hasSkill",
          "@type": "@id",
          "@container": "@set"
        },
        "knowledge_bases": {
          "@id": "workato:hasKnowledgeBase",
          "@type": "@id",
          "@container": "@set"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Skill": {
      "@id": "workato:Skill",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "schema:description"
        },
        "recipe_id": {
          "@id": "workato:recipeId",
          "@type": "xsd:integer"
        },
        "folder_id": {
          "@id": "workato:folderId",
          "@type": "xsd:integer"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "KnowledgeBase": {
      "@id": "workato:KnowledgeBase",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "schema:description"
        },
        "source_type": {
          "@id": "workato:sourceType"
        },
        "folder_id": {
          "@id": "workato:folderId",
          "@type": "xsd:integer"
        },
        "data_sources": {
          "@id": "workato:hasDataSource",
          "@type": "@id",
          "@container": "@set"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "DataSource": {
      "@id": "workato:DataSource",
      "@context": {
        "id": "@id",
        "source_type": {
          "@id": "workato:sourceType"
        },
        "connection_id": {
          "@id": "workato:connectionId",
          "@type": "xsd:integer"
        },
        "sync_frequency": {
          "@id": "workato:syncFrequency"
        },
        "config": {
          "@id": "workato:config"
        }
      }
    },

    "McpServer": {
      "@id": "workato:McpServer",
      "@context": {
        "handle": {
          "@id": "schema:identifier"
        },
        "name": {
          "@id": "schema:name"
        },
        "mcp_url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "authentication_method": {
          "@id": "workato:authenticationMethod"
        },
        "folder_id": {
          "@id": "workato:folderId",
          "@type": "xsd:integer"
        },
        "tools": {
          "@id": "workato:hasTool",
          "@type": "@id",
          "@container": "@set"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "McpTool": {
      "@id": "workato:McpTool",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "schema:description"
        },
        "trigger_application": {
          "@id": "workato:triggerApplication"
        }
      }
    },

    "Connection": {
      "@id": "workato:Connection",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "provider": {
          "@id": "schema:provider"
        },
        "authorized": {
          "@id": "workato:authorized",
          "@type": "xsd:boolean"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "DataTable": {
      "@id": "workato:DataTable",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "folder_id": {
          "@id": "workato:folderId",
          "@type": "xsd:integer"
        },
        "schema": {
          "@id": "workato:tableSchema",
          "@container": "@set"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "EventTopic": {
      "@id": "workato:EventTopic",
      "@context": {
        "id": "@id",
        "name": {
          "@id": "schema:name"
        },
        "description": {
          "@id": "schema:description"
        },
        "schema": {
          "@id": "workato:topicSchema"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    }
  }
}
