          "request": {
            "name": "Workato Consume Messages from a Topic",
            "description": {
              "content": "Retrieves messages from an event topic. Supports filtering by message ID or timestamp, configurable batch sizes up to 50, and long polling with timeouts up to 60 seconds. Returns at most 50 messages per request.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "v1",
                "topics",
                ":topic_id",
                "consume"
              ],
              "host": [
                "{{baseUrl}}"
              ],
