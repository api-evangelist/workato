              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the genie."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Removes one or more skills from an AI agent (genie)."
        },
