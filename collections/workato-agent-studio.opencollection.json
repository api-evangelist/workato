        {
          "info": {
            "name": "Workato Remove User Groups from a Genie",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://www.workato.com/api/agentic/genies/:id/remove_user_groups",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Unique identifier of the genie."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Removes identity provider user groups from an AI agent (genie)."
        }
